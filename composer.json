{
    "name": "bleeld/think-jump",
    "description": "ThinkPHP 8.0 跳转扩展，提供 success/error/redirect/result 方法",
    "type": "library",
    "keywords": [
        "thinkphp",
        "jump",
        "redirect",
        "success",
        "error"
    ],
    "homepage": "https://github.com/bleeld/think-jump",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "bleeld",
            "email": "bleeld@example.com"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "topthink/framework": "^8.0",
        "topthink/think-view": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "think\\": "src/"
        }
    },
    "extra": {
        "think": {
            "config": {
                "jump": "config/jump.php"
            }
        }
    },
    "minimum-stability": "stable"
}
